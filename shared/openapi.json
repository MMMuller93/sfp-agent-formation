  "components": {
    "schemas": {
      "ActionItem": {
        "properties": {
          "action": {
            "type": "string",
            "title": "Action",
            "description": "Machine-readable action identifier"
          },
          "endpoint": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Endpoint",
            "description": "API endpoint to call, if applicable"
          },
          "description": {
            "type": "string",
            "title": "Description",
            "description": "Human-readable guidance"
          },
          "required": {
            "type": "boolean",
            "title": "Required",
            "description": "Whether this action is mandatory to progress"
          }
        },
        "type": "object",
        "required": [
          "action",
          "description",
          "required"
        ],
        "title": "ActionItem",
        "description": "Describes a single action the caller should (or must) take next."
      },
      "AgentInput": {
        "properties": {
          "display_name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Display Name",
            "description": "Display name for the agent"
          },
          "authority_scope": {
            "additionalProperties": true,
            "type": "object",
            "title": "Authority Scope",
            "description": "JSON object describing what the agent is authorised to do"
          },
          "transaction_limit_cents": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Transaction Limit Cents",
            "description": "Per-transaction spending limit in cents"
          }
        },
        "type": "object",
        "required": [
          "display_name",
          "authority_scope"
        ],
        "title": "AgentInput",
        "description": "An AI agent to register as part of the entity structure.",
        "examples": [
          {
            "authority_scope": {
              "can_initiate_wires": true,
              "can_sign_checks": true,
              "max_single_wire_cents": 5000000
            },
            "display_name": "Treasury Agent v1.2",
            "transaction_limit_cents": 10000000
          }
        ]
      },
      "CreateOrderRequest": {
        "properties": {
          "jurisdiction": {
            "type": "string",
            "maxLength": 10,
            "minLength": 2,
            "title": "Jurisdiction",
            "description": "State code, e.g. DE, WY"
          },
          "vehicle_type": {
            "type": "string",
            "title": "Vehicle Type",
            "description": "Entity type: llc | dao_llc | corporation"
          },
          "requested_name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Requested Name",
            "description": "Desired entity name"
          },
          "service_tier": {
            "type": "string",
            "title": "Service Tier",
            "description": "Service tier: self_serve | managed | autonomous",
            "default": "self_serve"
          },
          "members": {
            "items": {
              "$ref": "#/components/schemas/MemberInput"
            },
            "type": "array",
            "minItems": 1,
            "title": "Members",
            "description": "At least one member is required"
          },
          "agent": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/AgentInput"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional AI agent to register"
          },
          "metadata": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Metadata",
            "description": "Arbitrary metadata to store with the order"
          }
        },
        "type": "object",
        "required": [
          "jurisdiction",
          "vehicle_type",
          "requested_name",
          "members"
        ],
        "title": "CreateOrderRequest",
        "description": "Payload for ``POST /v1/entity-orders``.",
        "examples": [
          {
            "agent": {
              "authority_scope": {
                "can_initiate_wires": true,
                "can_sign_checks": true
              },
              "display_name": "Treasury Agent v1.2",
              "transaction_limit_cents": 10000000
            },
            "jurisdiction": "DE",
            "members": [
              {
                "email": "jane@example.com",
                "legal_name": "Jane Doe",
                "ownership_percentage": 100.0,
                "role": "member"
              }
            ],
            "metadata": {
              "campaign": "launch_q1",
              "source": "api"
            },
            "requested_name": "Meridian Autonomous Holdings LLC",
            "service_tier": "managed",
            "vehicle_type": "llc"
          }
        ]
      },
      "CreateWebhookRequest": {
        "properties": {
          "url": {
            "type": "string",
            "maxLength": 2083,
            "minLength": 1,
            "format": "uri",
            "title": "Url",
            "description": "HTTPS URL to receive webhook POST requests"
          },
          "events": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "minItems": 1,
            "title": "Events",
            "description": "Event types to subscribe to, e.g. [\"order.state_changed\", \"order.completed\", \"filing.confirmed\"]"
          }
        },
        "type": "object",
        "required": [
          "url",
          "events"
        ],
        "title": "CreateWebhookRequest",
        "description": "Payload for ``POST /v1/webhooks``.",
        "examples": [
          {
            "events": [
              "order.state_changed",
              "order.completed"
            ],
            "url": "https://example.com/webhooks/sfp"
          }
        ]
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "version": {
            "type": "string",
            "title": "Version"
          }
        },
        "type": "object",
        "required": [
          "status",
          "version"
        ],
        "title": "HealthResponse"
