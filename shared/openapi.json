              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/entity-orders/{order_id}/activate": {
      "post": {
        "tags": [
          "entity-orders"
        ],
        "summary": "Activate entity",
        "description": "Mark the entity as fully formed and active. Transitions bank_pack_ready -> active.",
        "operationId": "activate_entity_v1_entity_orders__order_id__activate_post",
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
