# =============================================================
# SFP Entity Formation API — Environment Variables
# Copy to .env and fill in real values.
# All variables are prefixed with SFP_ in the environment.
# =============================================================

# --- Core ---
SFP_ENVIRONMENT=development
SFP_BASE_URL=http://localhost:8000
SFP_SECRET_KEY=change-me-to-a-random-64-char-string
SFP_API_KEY_SALT=sfp-api-key-salt

# --- Databases ---
SFP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sfp_formation
SFP_PII_VAULT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sfp_pii_vault

# --- PII Encryption ---
# Base64-encoded 256-bit key for PII vault encryption.
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Required in production.
SFP_PII_KEK=

# --- Stripe ---
SFP_STRIPE_SECRET_KEY=sk_test_...
SFP_STRIPE_WEBHOOK_SECRET=whsec_...

# --- AWS S3 (document storage) ---
SFP_S3_BUCKET=sfp-formation-docs
SFP_S3_REGION=us-east-1

# --- CORS ---
# Comma-separated list of allowed origins (parsed as JSON array)
SFP_CORS_ORIGINS=["http://localhost:5173"]

# --- Compliance ---
SFP_OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml
